mode: expression

tests:
# DRA device selector expressions — standalone CEL (no policy structure).
# These test the kinds of expressions used in ResourceClaim device selectors,
# evaluated using the base K8s CEL environment (not the full DRA env).
#
# NOTE: Real DRA selectors use `device.attributes["domain"].key`, not `object.attributes.key`.
# This example uses `object.*` because the full DRA environment (Phase 3) is not yet
# implemented. Once Phase 3 ships with EvalDRASelector and the typed `device` variable,
# these expressions should be rewritten to use the real DRA variable model.
# The Semver type IS available in the base env since K8s 1.33 (library.SemverLib).

- name: "GPU memory above threshold"
  expression: "object.attributes.memory >= 8"
  object:
    attributes:
      memory: 16
      driver: "nvidia.com"
  expect:
    value: true

- name: "GPU memory below threshold"
  expression: "object.attributes.memory >= 8"
  object:
    attributes:
      memory: 4
      driver: "nvidia.com"
  expect:
    value: false

- name: "driver name filter"
  expression: 'object.driver == "nvidia.com"'
  object:
    driver: "nvidia.com"
    attributes:
      memory: 16
  expect:
    value: true

- name: "driver name mismatch"
  expression: 'object.driver == "nvidia.com"'
  object:
    driver: "amd.com"
    attributes:
      memory: 16
  expect:
    value: false

- name: "compound selector — driver AND memory"
  expression: 'object.driver == "nvidia.com" && object.attributes.memory >= 8'
  object:
    driver: "nvidia.com"
    attributes:
      memory: 16
  expect:
    value: true

- name: "compound selector fails on memory"
  expression: 'object.driver == "nvidia.com" && object.attributes.memory >= 8'
  object:
    driver: "nvidia.com"
    attributes:
      memory: 4
  expect:
    value: false

- name: "string attribute check"
  expression: 'object.attributes.model == "A100"'
  object:
    attributes:
      model: "A100"
      memory: 80
  expect:
    value: true

- name: "list contains check for capabilities"
  expression: 'object.capabilities.exists(c, c == "tensor-cores")'
  object:
    capabilities:
      - "tensor-cores"
      - "ray-tracing"
  expect:
    value: true

- name: "missing capability"
  expression: 'object.capabilities.exists(c, c == "tensor-cores")'
  object:
    capabilities:
      - "ray-tracing"
  expect:
    value: false
